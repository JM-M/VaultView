{
  "manifest_version": 3,
  "name": "VaultView",
  "description": "High-speed local multimedia browser",
  "version": "0.1.0",
  "permissions": ["storage", "unlimitedStorage"],
  "action": {
    "default_title": "Open VaultView",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
